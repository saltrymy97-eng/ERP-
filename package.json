{
  "name": "alquran-attendance-system",
  "version": "1.0.0",
  "description": "نظام متابعة حضور وغياب الطلاب - جامعة القرآن الكريم والعلوم الإسلامية",
  "main": "App.js",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "dist": "electron-builder",
    "capacitor:add": "npx cap add windows && npx cap add android",
    "capacitor:sync": "npx cap sync",
    "capacitor:open:win": "npx cap open windows",
    "capacitor:open:android": "npx cap open android"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "framer-motion": "^11.0.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.10.0",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.0",
    "xlsx": "^0.18.5",
    "qrcode": "^1.5.3",
    "qrcode.react": "^3.1.0",
    "axios": "^1.6.0",
    "sql.js": "^1.9.0"
  },
  "devDependencies": {
    "react-scripts": "5.0.1",
    "@capacitor/core": "^5.6.0",
    "@capacitor/cli": "^5.6.0",
    "@capacitor/windows": "^5.6.0",
    "@capacitor/android": "^5.6.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "author": "سالم التريمي",
  "license": "MIT",
  "homepage": "https://alquran.vercel.app",
  "build": {
    "appId": "com.alquran.attendance",
    "productName": "نظام الحضور والغياب",
    "directories": {
      "output": "dist-exe"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico"
    }
  },
  "browserslist": {
    "production": [">0.2%", "not dead", "not op_mini all"],
    "development": ["last 1 chrome version", "last 1 firefox version", "last 1 safari version"]
  }
}
