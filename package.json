{
  "name": "alquran-attendance-system",
  "version": "1.0.0",
  "description": "نظام متابعة حضور وغياب الطلاب - جامعة القرآن الكريم والعلوم الإسلامية",
  "main": "electron/main.js",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "electron": "npm run build && electron .",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "framer-motion": "^11.0.0",
    "react-icons": "^5.0.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.10.0",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.0",
    "xlsx": "^0.18.5",
    "qrcode": "^1.5.3",
    "qrcode.react": "^3.1.0",
    "axios": "^1.6.0",
    "sql.js": "^1.9.0",
    "@xenova/transformers": "^2.0.0",
    "@vladmandic/face-api": "^1.7.14",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.alquran.attendance",
    "productName": "نظام الحضور والغياب",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    }
  },
  "author": "سالم التريمي",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "browserslist": {
    "production": [">0.2%", "not dead", "not op_mini all"],
    "development": ["last 1 chrome version", "last 1 firefox version", "last 1 safari version"]
  }
